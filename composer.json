{
  "name": "webfarben/contao-dummy-copier",
  "description": "Contao backend module to clone dummy pages, content elements, modules and rewire references.",
  "type": "contao-bundle",
  "license": "proprietary",
  "keywords": [
    "contao",
    "contao-bundle",
    "backend",
    "dummy",
    "migration",
    "cloner"
  ],
  "homepage": "https://github.com/webfarben/DummyCopier",
  "support": {
    "source": "https://github.com/webfarben/DummyCopier",
    "issues": "https://github.com/webfarben/DummyCopier/issues"
  },
  "authors": [
    {
      "name": "Webfarben"
    }
  ],
  "require": {
    "php": "^8.1",
    "contao/core-bundle": "^4.13 || ^5.0",
    "contao/manager-plugin": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Webfarben\\DummyCopier\\": "src/"
    }
  },
  "extra": {
    "contao-manager-plugin": "Webfarben\\DummyCopier\\ContaoManager\\Plugin"
  }
}
